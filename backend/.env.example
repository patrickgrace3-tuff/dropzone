# ── Required ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Render PostgreSQL connection string (copy from Render dashboard)
DATABASE_URL=postgresql://user:password@host/dbname

# Change this to any long random string
JWT_SECRET=change_this_to_a_long_random_secret

# Your frontend URL (update after deploying frontend to Render)
FRONTEND_URL=http://localhost:5173

# ── Optional ──────────────────────────────────────────────
# AI features (get key at console.anthropic.com)
ANTHROPIC_API_KEY=

# Payments (get key at stripe.com)
STRIPE_SECRET_KEY=

# Image uploads (get keys at cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
